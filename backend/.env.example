# Backend Environment Variables — copy to .env and fill in values
DATABASE_URL=postgresql://user:password@host:5432/cuzicam
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string
AI_SERVICE_URL=http://localhost:8000
AI_SHARED_SECRET=replace_with_random_string
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
PORT=3001

# Email
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Chaos Window
CHAOS_HOUR_UTC=14
