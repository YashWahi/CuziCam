# Backend Environment Variables
PORT=4000
DATABASE_URL="postgresql://cuzicam_user:cuzicam_password@localhost:5432/cuzicam_db"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change_me_in_production_super_long_secret_key"
JWT_REFRESH_SECRET="change_me_refresh_secret_key"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# AI Service
AI_SERVICE_URL="http://localhost:8000"

# Email (Resend)
RESEND_API_KEY="your_resend_api_key"
EMAIL_FROM="noreply@cuzicam.com"

# App
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"
